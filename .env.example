# ─────────────────────────────────────────────
# PenTools — Environment Variables Template
# Copy to .env and fill in real values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=change-this-to-a-long-random-string-at-least-50-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
POSTGRES_DB=pentools
POSTGRES_USER=pentools
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_MAX_CONCURRENCY=20
CELERY_MIN_CONCURRENCY=4

# Security — Fernet key for encrypting sensitive params in DB
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=change-this-generate-with-fernet

# Flower (Celery monitor)
FLOWER_USER=admin
FLOWER_PASSWORD=change-this-flower-password

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=

# OAST / OOB Callbacks (optional — self-hosted interactsh)
INTERACTSH_SERVER=
INTERACTSH_TOKEN=

# External API Keys (all optional, user can also provide per-scan)
SHODAN_API_KEY=
HUNTER_IO_API_KEY=
GITHUB_TOKEN=
